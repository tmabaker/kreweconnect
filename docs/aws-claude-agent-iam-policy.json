{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadNoitSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:898774460279:secret:noit/*"
    },
    {
      "Sid": "ListSecretsForIndex",
      "Effect": "Allow",
      "Action": "secretsmanager:ListSecrets",
      "Resource": "*"
    }
  ]
}
