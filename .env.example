# Entra ID app registration (multi-tenant). Defaults are compiled into
# msalConfig.ts as fallbacks; override per environment here.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_REDIRECT_URI=

# Set to 'true' to run with mock data and no MSAL login
VITE_DEMO_MODE=false

# Set to 'true' to fetch directory data through the KreweConnect Functions
# API (required for cross-tenant/GDAP access). 'false' = legacy direct-Graph
# mode, which can only ever read the signed-in user's home tenant.
VITE_USE_BACKEND_API=true

# Base URL of the Functions API. Leave as /api when served by Static Web
# Apps (managed functions) or behind the vite dev proxy.
VITE_API_BASE_URL=/api
